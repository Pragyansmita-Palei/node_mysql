//users
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,

    userName VARCHAR(191) NOT NULL,

    email VARCHAR(191) NOT NULL UNIQUE,

    password VARCHAR(255) NOT NULL,

    address JSON,

    phone VARCHAR(20) NOT NULL,

    usertype ENUM('client', 'admin', 'vendor', 'driver')
    NOT NULL DEFAULT 'client',

    profile VARCHAR(500) DEFAULT 'https://stock.adobe.com/images/user-icon-in-flat-style-person-icon-user-icon-for-web-site-user-icon-vector-illustration/229758328',

    answer VARCHAR(255) NOT NULL,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    ON UPDATE CURRENT_TIMESTAMP
);

//
CREATE TABLE restaurants (
  id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,

  title VARCHAR(255) NOT NULL,
  imageUrl TEXT DEFAULT NULL,

  foods JSON DEFAULT NULL,

  time VARCHAR(100) DEFAULT NULL,

  pickup TINYINT(1) DEFAULT 1,
  delivery TINYINT(1) DEFAULT 1,
  isopen TINYINT(1) DEFAULT 1,

  logoUrl TEXT DEFAULT NULL,

  rating DECIMAL(2,1) DEFAULT 1,
  ratingCount VARCHAR(50) DEFAULT NULL,

  code VARCHAR(50) DEFAULT NULL,

  -- Coordinates (flattened)
  coord_id VARCHAR(100) DEFAULT NULL,
  latitude DECIMAL(10,7) DEFAULT NULL,
  latitudeDelta DECIMAL(10,7) DEFAULT NULL,
  longitude DECIMAL(10,7) DEFAULT NULL,
  longitudeDelta DECIMAL(10,7) DEFAULT NULL,
  address TEXT DEFAULT NULL,
  coord_title VARCHAR(255) DEFAULT NULL,

  createdAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updatedAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);